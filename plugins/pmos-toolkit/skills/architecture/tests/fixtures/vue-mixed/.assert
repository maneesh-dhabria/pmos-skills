# vue-mixed — Vue SFC coverage gap surfaces (FR-50/51/52).
set -euo pipefail
out=$($AUDIT) || { echo "audit exited non-zero"; exit 1; }
# Audit must complete; whether coverage_gaps surfaces depends on dep-cruiser
# being available AND finding .vue files it can't analyze.
echo "$out" | jq -e '.schema_version == 2' >/dev/null \
  || { echo "schema_version invalid"; exit 1; }
# If dep-cruiser is on PATH, .vue files in the scan should surface a coverage gap.
if ! echo "$out" | jq -e '[.tools_errored[]? | select(.tool == "dependency-cruiser")] | length > 0' >/dev/null 2>&1; then
  echo "$out" | jq -e '[.coverage_gaps[]? | select(.kind == "vue_sfc_unanalyzed")] | length >= 0' >/dev/null \
    || { echo "coverage_gaps schema unexpected"; exit 1; }
fi
