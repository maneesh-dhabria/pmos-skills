set -euo pipefail

# --baseline requires a git repo at the scan root (spec L172).
trap 'rm -rf .git' EXIT
rm -rf .git 2>/dev/null || true
git init -q .
git config user.email "test@test"
git config user.name "test"
git add -A
git -c commit.gpgsign=false commit -q -m "c1"

out=$($AUDIT . --baseline baseline.json) || { echo "audit with --baseline exited non-zero"; exit 1; }

echo "$out" | jq -e '.diff.new | type == "array"' >/dev/null \
  || { echo "diff.new not array"; exit 1; }
echo "$out" | jq -e '.diff.dropped | type == "array"' >/dev/null \
  || { echo "diff.dropped not array"; exit 1; }
echo "$out" | jq -e '.diff.unchanged | type == "array"' >/dev/null \
  || { echo "diff.unchanged not array"; exit 1; }

echo "$out" | jq -e '[.diff.new[] | .file] | contains(["src/new.py"])' >/dev/null \
  || { echo "expected src/new.py in diff.new"; echo "$out" | jq '.diff'; exit 1; }
echo "$out" | jq -e '[.diff.dropped[] | .file] | contains(["src/dropped.py"])' >/dev/null \
  || { echo "expected src/dropped.py in diff.dropped"; echo "$out" | jq '.diff'; exit 1; }
echo "$out" | jq -e '[.diff.unchanged[] | .file] | contains(["src/kept.py"])' >/dev/null \
  || { echo "expected src/kept.py in diff.unchanged"; echo "$out" | jq '.diff'; exit 1; }
