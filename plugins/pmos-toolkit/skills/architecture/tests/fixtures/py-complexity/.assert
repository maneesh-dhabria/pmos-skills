# py-complexity — C901 (cyclomatic complexity > 10) must fire as PY005 (FR-31).
set -euo pipefail
out=$($AUDIT) || { echo "audit exited non-zero"; exit 1; }
if echo "$out" | jq -e '[.tools_errored[]? | select(.tool == "ruff")] | length > 0' >/dev/null 2>&1; then
  echo "ruff not on PATH; PY rules auto-skipped (FR-32) — pass."
  exit 0
fi
echo "$out" | jq -e '[.findings[] | select(.rule_id=="PY005")] | length == 1' >/dev/null \
  || { echo "expected exactly 1 PY005 finding"; echo "$out" | jq '[.findings[] | select(.rule_id=="PY005")]'; exit 1; }
# Lock in fixture minimality: only the target rule may fire from the PY family.
other_py_count=$(echo "$out" | jq '[.findings[] | select((.rule_id | startswith("PY")) and .rule_id != "PY005")] | length')
if [ "$other_py_count" -ne 0 ]; then
  echo "FAIL: expected only PY005, got other PY rules: $(echo "$out" | jq '[.findings[] | select(.rule_id | startswith("PY"))] | map(.rule_id) | unique')"
  exit 1
fi
