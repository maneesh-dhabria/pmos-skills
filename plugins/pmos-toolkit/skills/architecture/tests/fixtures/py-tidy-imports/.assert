# py-tidy-imports — Python L2 rules dispatch via ruff (FR-31).
set -euo pipefail
out=$($AUDIT) || { echo "audit exited non-zero"; exit 1; }
if echo "$out" | jq -e '[.tools_errored[]? | select(.tool == "ruff")] | length > 0' >/dev/null 2>&1; then
  echo "ruff not on PATH; PY rules auto-skipped (FR-32) — pass."
  exit 0
fi
# When ruff is available, audit must complete cleanly with no schema corruption.
echo "$out" | jq -e '.schema_version == 2' >/dev/null \
  || { echo "schema_version corrupted under ruff path"; exit 1; }
