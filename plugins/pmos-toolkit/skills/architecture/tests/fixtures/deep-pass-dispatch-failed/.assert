set -euo pipefail
# Empty mock.result simulates dispatch_failed (E5b).
touch mock.result
out=$(FIXTURE=1 $AUDIT . --deep --deep-finalize-from mock.result) || { echo "audit exited non-zero"; exit 1; }
echo "$out" | jq -e '.deep_pass.skipped_reason == "dispatch_failed"' >/dev/null \
  || { echo "expected dispatch_failed"; echo "$out" | jq '.deep_pass'; exit 1; }
