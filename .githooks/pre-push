#!/usr/bin/env bash
# Pre-push hook: enforce plugin version bumps when plugin content changes.
#
# For each ref being pushed, find plugins under `plugins/<name>/` that have
# modified files in the range remote..local. For each such plugin, require:
#   1. .claude-plugin/plugin.json `version` differs between remote tip and local tip.
#   2. .codex-plugin/plugin.json `version` matches .claude-plugin/plugin.json at local tip.
#
# Without this, Claude Code / Codex serve a stale version-keyed cache and
# never see the new skill content.

set -euo pipefail

ZERO="0000000000000000000000000000000000000000"
fail=0

get_version() {
  # get_version <ref> <path>
  # Returns the version string from a JSON manifest at <ref>:<path>, or empty string
  # when the file does not exist at <ref> (e.g., pushing to an empty remote where the
  # base is the empty-tree SHA). Wrapped in `|| true` so `set -euo pipefail` doesn't
  # exit when `git show` returns non-zero for a missing path.
  local ref="$1" path="$2"
  { git show "$ref:$path" 2>/dev/null || true; } | sed -n 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n1
}

command -v jq >/dev/null || { echo "pre-push: jq not installed; required for marketplace.json / tag checks." >&2; exit 1; }

existing_tags=$(git ls-remote --tags origin 2>/dev/null | awk '{print $2}' | sed 's#refs/tags/##;s#\^{}##' | sort -u || true)
for tag in $(git tag --points-at HEAD 2>/dev/null); do
  printf '%s\n' "$existing_tags" | grep -qx "$tag" && continue
  if ! echo "$tag" | grep -qE '^[^/]+/v[0-9]+\.[0-9]+\.[0-9]+$'; then
    echo "ERROR: tag '$tag' has invalid format — expected <plugin>/v<semver>." >&2
    fail=1
    continue
  fi
  tag_plugin=${tag%%/v*}; tag_v=${tag##*/v}
  cj=$(jq -r --arg n "$tag_plugin" '.plugins[]|select(.name==$n)|.version' .claude-plugin/marketplace.json 2>/dev/null)
  xj=$(jq -r --arg n "$tag_plugin" '.plugins[]|select(.name==$n)|.version' .codex-plugin/marketplace.json 2>/dev/null)
  pv=$(jq -r '.version' "plugins/$tag_plugin/.claude-plugin/plugin.json" 2>/dev/null)
  xv=$(jq -r '.version' "plugins/$tag_plugin/.codex-plugin/plugin.json" 2>/dev/null)
  if [ "$tag_v" != "$cj" ] || [ "$tag_v" != "$xj" ] || [ "$tag_v" != "$pv" ] || [ "$tag_v" != "$xv" ]; then
    echo "ERROR: tag '$tag' version $tag_v does not match manifests (claude-plugin=$pv codex-plugin=$xv marketplace.claude=$cj marketplace.codex=$xj)." >&2
    fail=1
  fi
done

while read -r local_ref local_oid remote_ref remote_oid; do
  # Deleting a remote branch — nothing to check.
  [ "$local_oid" = "$ZERO" ] && continue

  # Tag refs: per-ref version validation does not apply. The top-of-file
  # `git tag --points-at HEAD` loop handles version-bump tags for the
  # current HEAD; historical tags (e.g., pushed from --tags on an initial
  # mirror push) MUST NOT be retroactively validated against the current
  # marketplace.json (per FR-43). Skip cleanly.
  case "$local_ref" in refs/tags/*) continue ;; esac

  # New branch on remote: diff against merge-base with origin/HEAD if available,
  # else against the empty tree.
  if [ "$remote_oid" = "$ZERO" ]; then
    base=$(git merge-base "$local_oid" origin/HEAD 2>/dev/null || echo "")
    [ -z "$base" ] && base=$(git hash-object -t tree /dev/null)
  else
    base="$remote_oid"
  fi

  changed=$(git diff --name-only "$base" "$local_oid" 2>/dev/null | grep -E '^plugins/[^/]+/(skills|agents|\.claude-plugin|\.codex-plugin)/' || true)
  [ -z "$changed" ] && continue

  plugins=$(echo "$changed" | awk -F/ '{print $2}' | sort -u)

  for plugin in $plugins; do
    claude_json="plugins/$plugin/.claude-plugin/plugin.json"
    codex_json="plugins/$plugin/.codex-plugin/plugin.json"

    # Only enforce for plugins that actually have a content change (skills/ or agents/).
    plugin_changed=$(echo "$changed" | grep -E "^plugins/$plugin/(skills|agents)/" || true)
    [ -z "$plugin_changed" ] && continue

    local_v=$(get_version "$local_oid" "$claude_json")
    remote_v=$(get_version "$base" "$claude_json")

    if [ -z "$local_v" ]; then
      echo "ERROR: $claude_json missing or no version field at local tip." >&2
      fail=1
      continue
    fi

    if [ "$local_v" = "$remote_v" ]; then
      echo "ERROR: $plugin content changed but $claude_json version unchanged ($local_v)." >&2
      echo "       Bump the version (patch for clarifications, minor for new behavior, major for breaking)." >&2
      fail=1
    fi

    codex_v=$(get_version "$local_oid" "$codex_json")
    if [ -z "$codex_v" ]; then
      echo "ERROR: $codex_json missing or no version field at local tip." >&2
      fail=1
    elif [ "$codex_v" != "$local_v" ]; then
      echo "ERROR: $plugin version drift — .claude-plugin=$local_v .codex-plugin=$codex_v." >&2
      echo "       Both manifests must carry the same version." >&2
      fail=1
    fi

    mc=$(jq -r --arg n "$plugin" '.plugins[]|select(.name==$n)|.version' .claude-plugin/marketplace.json 2>/dev/null)
    mx=$(jq -r --arg n "$plugin" '.plugins[]|select(.name==$n)|.version' .codex-plugin/marketplace.json 2>/dev/null)
    if [ "$mc" != "$local_v" ] || [ "$mx" != "$local_v" ]; then
      echo "ERROR: $plugin marketplace drift — plugin.json=$local_v marketplace.claude=$mc marketplace.codex=$mx." >&2
      fail=1
    fi
  done
done

exit $fail
