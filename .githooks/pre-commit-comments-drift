#!/usr/bin/env bash
# T25 — pre-commit comments-sidecar pairing drift hook (FR-15, S5).
# Refuses commits where an HTML artifact under docs/pmos/ is staged but
# its sibling .comments.json sidecar is not (or vice versa).
# Bypassable via --no-verify per S5.
set -euo pipefail

staged=$(git diff --cached --name-only)

# Collect staged HTML files under docs/pmos/
staged_html=$(echo "$staged" | grep -E '^docs/pmos/.+\.html?$' || true)
staged_sidecars=$(echo "$staged" | grep -E '^docs/pmos/.+\.comments\.json$' || true)

fail=0
errors=""

# For each staged HTML, check sibling .comments.json
while IFS= read -r html; do
  [ -z "$html" ] && continue
  base="${html%.html}"
  base="${base%.htm}"
  sidecar="${base}.comments.json"
  if [ -f "$sidecar" ] && ! echo "$staged" | grep -qFx "$sidecar"; then
    errors+="comments-drift: ${html} is staged but its sibling ${sidecar} is not"$'\n'
    fail=1
  fi
done <<< "$staged_html"

# For each staged sidecar, check sibling HTML
while IFS= read -r sidecar; do
  [ -z "$sidecar" ] && continue
  base="${sidecar%.comments.json}"
  html="${base}.html"
  html_alt="${base}.htm"
  if [ -f "$html" ] && ! echo "$staged" | grep -qFx "$html"; then
    errors+="comments-drift: ${sidecar} is staged but its sibling ${html} is not"$'\n'
    fail=1
  elif [ -f "$html_alt" ] && ! echo "$staged" | grep -qFx "$html_alt"; then
    errors+="comments-drift: ${sidecar} is staged but its sibling ${html_alt} is not"$'\n'
    fail=1
  fi
done <<< "$staged_sidecars"

if [ "$fail" -eq 1 ]; then
  echo -n "$errors" >&2
  echo "Resolve: stage the missing sibling, or use 'git commit --no-verify' to bypass (S5)." >&2
  exit 1
fi

exit 0
