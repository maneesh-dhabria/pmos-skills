#!/usr/bin/env bash
# Pre-commit drift hook: reject commits whose staged diff causes plugins/*/skills/_shared/ drift.
# Per spec FR-30..FR-34.
set -euo pipefail

# Source comments-drift sub-hook (T25, FR-15)
hook_dir="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
if [ -x "${hook_dir}/pre-commit-comments-drift" ]; then
  "${hook_dir}/pre-commit-comments-drift" || exit $?
fi

staged=$(git diff --cached --name-only)
echo "$staged" | grep -q '^plugins/[^/]\+/skills/_shared/' || exit 0  # FR-33 short-circuit
peers=$(find plugins -maxdepth 3 -type d -name _shared | sort)
count=$(echo "$peers" | wc -l | tr -d ' ')
[ "$count" -lt 2 ] && exit 0  # FR-31 only-one-plugin
baseline=$(echo "$peers" | head -1)
fail=0
for p in $(echo "$peers" | tail -n +2); do
  if ! diff -rq "$baseline" "$p" >/dev/null 2>&1; then
    echo "_shared/ drift detected:" >&2
    echo "  $baseline  ->  $p" >&2
    { diff -rq "$baseline" "$p" 2>/dev/null || true; } | sed 's/^/    /' >&2
    echo "Resolve with: scripts/sync-shared.sh --from=$(basename $(dirname $(dirname $baseline)))" >&2
    fail=1
  fi
done
exit $fail
