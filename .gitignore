.DS_Store
.worktrees/
.claude/worktrees/

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# pmos-toolkit per-repo state (per-worktree state.yaml)
.pmos/feature-sdlc/

# pmos-toolkit per-repo session pointer
.pmos/current-feature

# pmos-toolkit per-developer /complete-dev run-shaping defaults (lastrun memory)
.pmos/complete-dev.lastrun.yaml

# pmos-toolkit per-developer /feature-sdlc soft-gate defaults (lastrun memory)
.pmos/feature-sdlc.lastrun.yaml

# Playwright MCP scratch artifacts (snapshots/console logs from /verify runs)
.playwright-mcp/

# Skill-local node_modules (e.g. architecture skill's dependency-cruiser devDep)
plugins/pmos-toolkit/skills/*/node_modules/
plugins/pmos-toolkit/skills/*/scripts/node_modules/
plugins/pmos-toolkit/skills/*/package-lock.json
plugins/pmos-toolkit/skills/*/scripts/package-lock.json

# Architecture skill — fixture ADRs are write-side-effects of regression runs; never committed.
plugins/pmos-toolkit/skills/architecture/tests/fixtures/*/docs/
# adr-reconcile fixtures keep tracked baseline ADRs 0001-0006 under */docs/adr/;
# regression runs append ADR-0007+ which must not be committed.
plugins/pmos-toolkit/skills/architecture/tests/fixtures/adr-reconcile/*/docs/adr/ADR-00[01][7-9]*-*.md
plugins/pmos-toolkit/skills/architecture/tests/fixtures/adr-reconcile/*/docs/adr/ADR-001[0-9]-*.md
plugins/pmos-toolkit/skills/architecture/tests/fixtures/adr-reconcile/*/docs/adr/ADR-00[2-9][0-9]-*.md

# Backlog claim locks are transient, machine-local O_EXCL lockfiles (D13) — never committed.
backlog/claims/

# /explainer-video live-smoke binary artifacts (runtime output, not source)
docs/pmos/explainer-video/*_msr-smoke/
